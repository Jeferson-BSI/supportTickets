{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@core/*": ["src/core/*"],
      "@features/*": ["src/features/*"],
      "@tests/*": ["src/tests/*"],
      "@theme/*": ["src/core/theme/*"],
      "@components/*": ["src/components/*"],
      "@navigation/*": ["src/navigation/*"]
    },
    "types": ["jest", "@testing-library/react-native"]
  },
  "include": ["**/*.ts", "**/*.tsx", "src"],
  "exclude": ["node_modules"]
}
